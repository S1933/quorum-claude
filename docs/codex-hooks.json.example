{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo $PWD)/scripts/quorum-hook-check.sh\"",
            "timeout": 120,
            "statusMessage": "Running Quorum review..."
          }
        ]
      }
    ]
  }
}