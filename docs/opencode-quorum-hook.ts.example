// .opencode/plugins/quorum-hook.ts
// OpenCode Go plugin to run Quorum review before git commits.
// Copy this file into your project's .opencode/plugins/ directory.
//
// Requires: quorum CLI or bun, jq, git

export async function plugin() {
  return {
    "tool.execute.before": async (input: { tool: string; args: Record<string, unknown> }) => {
      if (input.tool !== "bash") return;

      const cmd = String(input.args.command ?? "");
      const isGitCommit = /^(git commit|git commit\s)/.test(cmd.trim());

      if (!isGitCommit) return;

      const bypass = process.env.QUORUM_BYPASS === "1";
      if (bypass) return;

      const proc = Bun.spawnSync({
        cmd: ["bash", "scripts/quorum-hook-check.sh"],
      });

      if (proc.exitCode === 2) {
        throw new Error(
          `Quorum found high/critical findings. Set QUORUM_BYPASS=1 to bypass.\n${proc.stderr.toString()}`
        );
      }
    },
  };
}